            <rect key="contentRect" x="374" y="492" width="571" height="182"/>
            <rect key="screenRect" x="0.0" y="0.0" width="1710" height="1073"/>
            <view key="contentView" id="2">
                <rect key="frame" x="0.0" y="0.0" width="571" height="182"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <textField verticalHuggingPriority="750" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="3">
                        <rect key="frame" x="10" y="158" width="552" height="14"/>
